<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".home.HomeFragment">

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:fontFamily="sans-serif-black"
        android:text="Welcome!"
        android:textColor="#333333"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Silahkan pilih..."
        android:textColor="#666666"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvWelcome" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToSecond"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Pertemuan 2"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:backgroundTint="#673AB7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToThird"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Pertemuan 3"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:backgroundTint="#000000" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToFourth"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Pertemuan 4"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:backgroundTint="#9E9E9E" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToFifth"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Pertemuan 5"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:backgroundTint="#2196F3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToSixth"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="24dp"
                android:text="Pertemuan 6"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:backgroundTint="#00A859" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Logout"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:backgroundTint="#F44336" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>